<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- 1. Service Level Metric                                      -->
    <!-- ============================================================ -->
    <record id="view_icc_service_level_metric_tree" model="ir.ui.view">
        <field name="name">icc.service.level.metric.tree</field>
        <field name="model">icc.service.level.metric</field>
        <field name="arch" type="xml">
            <list>
                <field name="fecha"/>
                <field name="total_llamadas" optional="show"/>
                <field name="agentes_unicos" optional="show"/>
                <field name="avg_talk_time_segundos" string="Avg Talk Time (s)" optional="show"/>
                <field name="avg_acw_segundos" string="Avg ACW (s)" optional="show"/>
                <field name="avg_handle_time_segundos" string="Avg Handle (s)" optional="show"/>
                <field name="production_hours" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_icc_service_level_metric_search" model="ir.ui.view">
        <field name="name">icc.service.level.metric.search</field>
        <field name="model">icc.service.level.metric</field>
        <field name="arch" type="xml">
            <search>
                <field name="fecha"/>
                <filter name="year_2026" string="2026" domain="[('fecha','&gt;=','2026-01-01')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_month" string="Month" context="{'group_by': 'fecha:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_icc_service_level_metric" model="ir.actions.act_window">
        <field name="name">Service Level Metrics</field>
        <field name="res_model">icc.service.level.metric</field>
        <field name="view_mode">tree,form,pivot,graph</field>
        <field name="search_view_id" ref="view_icc_service_level_metric_search"/>
        <field name="context">{'search_default_year_2026': 1}</field>
    </record>

