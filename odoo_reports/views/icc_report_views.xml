<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View -->
    <record id="view_icc_report_form" model="ir.ui.view">
        <field name="name">icc.report.form</field>
        <field name="model">icc.report</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_generate" string="Generate Report" type="object"
                            class="oe_highlight"
                            invisible="state not in ['draft']"
                            confirm="This will execute the Python generation script. Continue?"/>
                    <button name="action_generate" string="Regenerate" type="object"
                            class="oe_highlight"
                            invisible="state not in ['generated', 'error']"
                            confirm="This will regenerate the report. Continue?"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,generated"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="buttons" invisible="state != 'generated'">
                        <button name="action_download" string="Download File" type="object" class="oe_highlight"/>
                    </div>
                    <div class="oe_title">
                        <label for="name" string="Report Name"/>
                        <h1><field name="name" placeholder="e.g. Service Level Report"/></h1>
                    </div>
                    <group>
                        <group string="Report Info">
                            <field name="report_key" widget="selection"/>
                            <field name="user_id"/>
                            <field name="generation_date"/>
                        </group>
                        <group string="File Info">
                            <field name="file_name"/>
                            <field name="file_size"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Generation Log" name="log">
                            <field name="generation_log" placeholder="Log output will appear here after generation..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="view_icc_report_list" model="ir.ui.view">
        <field name="name">icc.report.list</field>
        <field name="model">icc.report</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="report_key"/>
                <field name="state" widget="badge" decoration-success="state == 'generated'" decoration-danger="state == 'error'"/>
                <field name="file_name"/>
                <field name="file_size"/>
                <field name="generation_date"/>
                <field name="user_id"/>
            </list>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_icc_report_search" model="ir.ui.view">
        <field name="name">icc.report.search</field>
        <field name="model">icc.report</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="report_key"/>
                <filter name="generated" string="Generated" domain="[('state', '=', 'generated')]"/>
                <filter name="errors" string="Errors" domain="[('state', '=', 'error')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_by_type" string="Report Type" context="{'group_by': 'report_key'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_icc_report" model="ir.actions.act_window">
        <field name="name">ICC Amex Reports</field>
        <field name="res_model">icc.report</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_icc_report_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No reports generated yet.
            </p>
            <p>
                Click <strong>Generate Report</strong> on any report to run the Python generation script.
            </p>
        </field>
    </record>
</odoo>
